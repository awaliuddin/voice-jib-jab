{
  "name": "@nxtg/vjj-sdk",
  "version": "0.1.0",
  "description": "Browser and Node.js SDK for voice-jib-jab voice agent runtime",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs,iife --dts --global-name VjjSdk --out-dir dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "voice",
    "websocket",
    "ai",
    "speech",
    "enterprise"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
