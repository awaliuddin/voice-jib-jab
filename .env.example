# ── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── OpenAI (REQUIRED) ──────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-realtime-preview-2024-12-17

# ── Features ───────────────────────────────────────────
ENABLE_LANE_A=true
ENABLE_RAG=true
ENABLE_POLICY_GATE=true
ENABLE_AUDIT_TRAIL=true
ENABLE_PERSISTENT_MEMORY=true

# ── Latency targets (ms) ───────────────────────────────
TTFB_TARGET_P50=400
TTFB_TARGET_P95=900
BARGE_IN_TARGET_P95=250

# ── Safety ─────────────────────────────────────────────
ENABLE_PII_REDACTION=true
STORE_RAW_AUDIO=false
MAX_SESSION_DURATION_MINUTES=30

# ── RAG / Retrieval ────────────────────────────────────
RAG_TOP_K=5
RAG_MAX_TOKENS=600
RAG_MAX_BYTES=4000
CHROMA_URL=http://localhost:8000

# ── Storage (SQLite) ───────────────────────────────────
DATABASE_PATH=./data/voice-jib-jab.db
DATABASE_WAL_MODE=true
MAX_HISTORY_TURNS=20
MAX_SUMMARY_LENGTH=2000

# ── Fallback mode ──────────────────────────────────────
# Options: auto | ask_clarifying_question | refuse_politely |
#          switch_to_text_summary | escalate_to_human | offer_email_or_link
FALLBACK_MODE=auto

# ── OPA Policy Engine ──────────────────────────────────
ENABLE_OPA=false
OPA_BUNDLE_PATH=./server/policies/bundle.tar.gz

# ── Ticketing MCP (GitHub Issues escalation) ───────────
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# ── PostgreSQL (Docker Compose only) ───────────────────
POSTGRES_PASSWORD=vjj_dev
